<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Excluir preferencias cifradas y no cifradas del backup en la nube -->
        <exclude domain="sharedpref" path="secure_session.xml"/>
        <exclude domain="sharedpref" path="app.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Excluir también en transferencias de dispositivo a dispositivo -->
        <exclude domain="sharedpref" path="secure_session.xml"/>
        <exclude domain="sharedpref" path="app.xml"/>
    </device-transfer>
</data-extraction-rules>
