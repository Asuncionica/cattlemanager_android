<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp"/>
            <solid android:color="#5500695C"/>
            <stroke android:width="1.5dp" android:color="#80CBC4"/>
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp"/>
            <solid android:color="#4400897B"/>
            <stroke android:width="1.5dp" android:color="#80CBC4"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp"/>
            <solid android:color="#3300695C"/>
            <stroke android:width="1dp" android:color="#4480CBC4"/>
        </shape>
    </item>

</selector>
