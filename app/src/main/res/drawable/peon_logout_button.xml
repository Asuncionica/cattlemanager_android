<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#CC0A1A2B" />
            <stroke android:width="1.5dp" android:color="#1E88E5" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#AA0A1A2B" />
            <stroke android:width="1.5dp" android:color="#1E88E5" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#800A1A2B" />
            <stroke android:width="1.5dp" android:color="#1565C0" />
        </shape>
    </item>
</selector>
