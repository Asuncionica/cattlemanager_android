<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#CCF57F17" />
            <stroke android:width="1.5dp" android:color="#FFD54F" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#AAF57F17" />
            <stroke android:width="1.5dp" android:color="#FFD54F" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#80F57F17" />
            <stroke android:width="1.5dp" android:color="#F9A825" />
        </shape>
    </item>
</selector>
