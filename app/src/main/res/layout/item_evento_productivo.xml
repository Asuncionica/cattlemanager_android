<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    card_view:cardCornerRadius="14dp"
    card_view:cardElevation="6dp"
    card_view:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tvTipoEvento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Producción de leche"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvFechaEvento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha: 2026-03-01"
            android:textSize="16sp"
            android:textColor="#444444"
            android:layout_marginBottom="6dp"/>
        <TextView
            android:id="@+id/tvAnimalEvento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Animal: VACA-001"
            android:textSize="16sp"
            android:textColor="#444444"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvDescripcionEvento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción del evento"
            android:textSize="15sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDetalleEvento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👉 Ver detalle"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="end"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>