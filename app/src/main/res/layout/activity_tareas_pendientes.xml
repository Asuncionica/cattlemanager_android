<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/hero_tareas_oficina_granja"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/animales_overlay_gradient"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Peón"
                    android:textColor="#AAFFF8EA"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:shadowColor="#99000000"
                    android:shadowDx="0" android:shadowDy="1" android:shadowRadius="4"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:shadowColor="#CC000000"
                    android:shadowDx="0" android:shadowDy="3" android:shadowRadius="10"
                    android:text="Mis Tareas"
                    android:textColor="#FFF8EA"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvContadorPendientes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:shadowColor="#BB1565C0"
                    android:shadowDx="0" android:shadowDy="0" android:shadowRadius="8"
                    android:text=""
                    android:textColor="#82B1FF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/dashboard_logout_button"
                android:contentDescription="@null"
                android:elevation="4dp"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"/>
        </FrameLayout>

        <!-- Filtros -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFiltroPendientes"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#FFB74D"
                android:text="Pendientes"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#FFB74D"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFiltroTodas"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#00000000"
                android:text="Todas"
                android:textAllCaps="false"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#55FFFFFF"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFiltroCompletadas"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#00000000"
                android:text="Hechas"
                android:textAllCaps="false"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                app:cornerRadius="20dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#55FFFFFF"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTareasPendientes"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="20dp"
                android:scrollbars="vertical"
                android:fadeScrollbars="true"/>

            <LinearLayout
                android:id="@+id/layoutSinTareas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Sin tareas pendientes"
                    android:textColor="#CCFFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Estás al día. No tienes tareas asignadas."
                    android:textColor="#AAFFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
