<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#00FFFFFF">

    <LinearLayout
        android:id="@+id/layoutAlertaFondo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/alerta_item_pending">

        <View
            android:id="@+id/viewEstado"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:minHeight="72dp"
            android:background="#FF6F00"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvAnimalAlerta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvDescripcionAlerta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvMetaAlerta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAtender"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:backgroundTint="#FF6F00"
            android:text="Atender"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            app:cornerRadius="18dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
