<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Barra de color lateral: naranja = pendiente, verde = atendida -->
        <View
            android:id="@+id/viewEstado"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:minHeight="60dp"
            android:background="#FF6F00"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAnimalAlerta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"/>

            <TextView
                android:id="@+id/tvDescripcionAlerta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#444444"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvMetaAlerta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Botón "Atender" solo visible para pendientes (ocultado en adapter) -->
        <Button
            android:id="@+id/btnAtender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Atender"
            android:textSize="11sp"
            android:backgroundTint="#FF6F00"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:minHeight="0dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
