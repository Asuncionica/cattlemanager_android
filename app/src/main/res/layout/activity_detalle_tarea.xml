<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/hero_tareas_oficina_granja"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/animales_overlay_gradient"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="190dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="bottom"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:id="@+id/tvTituloDetalleTarea"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="serif"
                        android:shadowColor="#CC000000"
                        android:shadowDx="0" android:shadowDy="3" android:shadowRadius="10"
                        android:text="Tarea"
                        android:textColor="#FFF8EA"
                        android:textSize="28sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvEstadoDetalleTarea"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="Pendiente"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnVolver"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/dashboard_logout_button"
                    android:contentDescription="@null"
                    android:elevation="4dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_arrow_back"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/peon_card_panel">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="Vencimiento" android:textColor="#AAFFFFFF" android:textSize="12sp" android:textAllCaps="true"/>
                        <TextView android:id="@+id/tvFechaDetalleTarea" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#33FFFFFF" android:layout_marginBottom="10dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="Peón" android:textColor="#AAFFFFFF" android:textSize="12sp" android:textAllCaps="true"/>
                        <TextView android:id="@+id/tvPeonDetalleTarea" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:textColor="#82B1FF" android:textSize="15sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#33FFFFFF" android:layout_marginBottom="10dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="top">
                        <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                            android:text="Descripción" android:textColor="#AAFFFFFF" android:textSize="12sp" android:textAllCaps="true"/>
                        <TextView android:id="@+id/tvDescripcionDetalleTarea" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:textColor="#FFFFFF" android:textSize="15sp"/>
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleCompletada"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="10dp"
                    android:backgroundTint="#1565C0"
                    android:text="Marcar como completada"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBorrarTarea"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="#C62828"
                    android:text="Eliminar tarea"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
