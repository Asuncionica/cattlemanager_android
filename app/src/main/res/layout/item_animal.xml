<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:id="@+id/layoutFondo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <View
            android:id="@+id/viewSexoBarra"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#2E7D32" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código: VACA-000"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

            <TextView
                android:id="@+id/tvRazaEdad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Raza: Holando · 0 meses"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:textColor="#555555"/>

            <TextView
                android:id="@+id/tvLoteGenetico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lote: Sin Asignar"
                android:textSize="12sp"
                android:textStyle="italic"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="#E8F5E9"
                android:textColor="#2E7D32"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSexoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="16dp"
            android:text="♀"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#555555"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>