<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/hero_veterinario_tratamiento"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/vet_overlay_gradient"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="92dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Cabecera -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:shadowColor="#99000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    android:text="Veterinario"
                    android:textColor="#AAFFF8EA"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="serif"
                    android:shadowColor="#CC000000"
                    android:shadowDx="0"
                    android:shadowDy="3"
                    android:shadowRadius="10"
                    android:text="Eventos Reproductivos"
                    android:textColor="#FFF8EA"
                    android:textSize="30sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvContadorReproductivos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:shadowColor="#BB00695C"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    android:text=""
                    android:textColor="#80CBC4"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardParto"
                        android:layout_width="0dp"
                        android:layout_height="148dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/dashboard_transparent_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Parto"
                                android:textColor="#FFFFFF"
                                android:textSize="19sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Nacimiento"
                                android:textColor="#CCFFFFFF"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardInseminacion"
                        android:layout_width="0dp"
                        android:layout_height="148dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/dashboard_transparent_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Inseminación"
                                android:textColor="#FFFFFF"
                                android:textSize="19sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Reproducción"
                                android:textColor="#CCFFFFFF"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardCelo"
                        android:layout_width="0dp"
                        android:layout_height="148dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/dashboard_transparent_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Celo"
                                android:textColor="#FFFFFF"
                                android:textSize="19sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Ciclo estral"
                                android:textColor="#CCFFFFFF"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardRevision"
                        android:layout_width="0dp"
                        android:layout_height="148dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/dashboard_transparent_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Revisión"
                                android:textColor="#FFFFFF"
                                android:textSize="19sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Seguimiento"
                                android:textColor="#CCFFFFFF"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/btnVolver"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/dashboard_logout_button"
        android:contentDescription="@null"
        android:elevation="6dp"
        android:padding="12dp"
        android:src="@drawable/ic_arrow_back"/>

</FrameLayout>
