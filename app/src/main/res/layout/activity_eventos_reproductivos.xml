<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/hero_veterinario_tratamiento"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/vet_overlay_gradient"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Veterinario"
                    android:textColor="#AAFFF8EA"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:shadowColor="#99000000"
                    android:shadowDx="0" android:shadowDy="1" android:shadowRadius="4"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:shadowColor="#CC000000"
                    android:shadowDx="0" android:shadowDy="3" android:shadowRadius="10"
                    android:text="Eventos Reproductivos"
                    android:textColor="#FFF8EA"
                    android:textSize="26sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvContadorReproductivos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:shadowColor="#BB00695C"
                    android:shadowDx="0" android:shadowDy="0" android:shadowRadius="8"
                    android:text=""
                    android:textColor="#80CBC4"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/dashboard_logout_button"
                android:contentDescription="@null"
                android:elevation="4dp"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardParto"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:clickable="true" android:focusable="true"
                    app:cardCornerRadius="14dp" app:cardElevation="6dp"
                    app:cardBackgroundColor="#00FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical"
                        android:background="@drawable/repro_item_card">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Parto" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="#FFFFFF" android:shadowColor="#CC000000"
                            android:shadowDx="0" android:shadowDy="2" android:shadowRadius="6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="6dp" android:text="Nacimiento"
                            android:textSize="12sp" android:textColor="#80CBC4"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardInseminacion"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    android:clickable="true" android:focusable="true"
                    app:cardCornerRadius="14dp" app:cardElevation="6dp"
                    app:cardBackgroundColor="#00FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical"
                        android:background="@drawable/repro_item_card">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Insem." android:textSize="22sp" android:textStyle="bold"
                            android:textColor="#FFFFFF" android:shadowColor="#CC000000"
                            android:shadowDx="0" android:shadowDy="2" android:shadowRadius="6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="6dp" android:text="Reproducción"
                            android:textSize="12sp" android:textColor="#80CBC4"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCelo"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:clickable="true" android:focusable="true"
                    app:cardCornerRadius="14dp" app:cardElevation="6dp"
                    app:cardBackgroundColor="#00FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical"
                        android:background="@drawable/repro_item_card">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Celo" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="#FFFFFF" android:shadowColor="#CC000000"
                            android:shadowDx="0" android:shadowDy="2" android:shadowRadius="6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="6dp" android:text="Ciclo estral"
                            android:textSize="12sp" android:textColor="#80CBC4"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRevision"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    android:clickable="true" android:focusable="true"
                    app:cardCornerRadius="14dp" app:cardElevation="6dp"
                    app:cardBackgroundColor="#00FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical"
                        android:background="@drawable/repro_item_card">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Revisión" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="#FFFFFF" android:shadowColor="#CC000000"
                            android:shadowDx="0" android:shadowDy="2" android:shadowRadius="6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="6dp" android:text="Seguimiento"
                            android:textSize="12sp" android:textColor="#80CBC4"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
