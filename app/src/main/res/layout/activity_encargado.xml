<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/hero_ganaderia_realista" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/vet_overlay_gradient" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="92dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Cabecera -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:shadowColor="#99000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    android:text="Bienvenido,"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvNombreUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="serif"
                    android:shadowColor="#CC000000"
                    android:shadowDx="0"
                    android:shadowDy="3"
                    android:shadowRadius="10"
                    android:text=""
                    android:textColor="#FFF8EA"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:shadowColor="#BBE65100"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="10"
                    android:text="Gestión de Granja"
                    android:textColor="#FF8F00"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Cards 2x3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="22dp">

                <!-- Fila 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnAnimalesEnc"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        android:stateListAnimator="@animator/dashboard_card_state"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/encargado_card_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Animales"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Gestión del rebaño"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnUsuarios"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        android:stateListAnimator="@animator/dashboard_card_state"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/encargado_card_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Empleados"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Personal y roles"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Fila 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnProduccionEnc"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        android:stateListAnimator="@animator/dashboard_card_state"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/encargado_card_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Producción"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Control productivo"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnGranja"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        android:stateListAnimator="@animator/dashboard_card_state"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/encargado_card_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Granja"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Instalaciones"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Fila 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnTareas"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        android:stateListAnimator="@animator/dashboard_card_state"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/encargado_card_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Tareas"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Asignar y seguir"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnAlertasVet"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        android:stateListAnimator="@animator/dashboard_card_state"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/encargado_card_panel"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Avisar Vet"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:maxLines="1"
                                android:text="Alertas sanitarias"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/btnCerrarSesion"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/encargado_logout_button"
        android:contentDescription="@null"
        android:elevation="6dp"
        android:padding="14dp"
        android:src="@drawable/ic_power" />

</FrameLayout>
