<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#FFFDF5"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:padding="24dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tvTituloGranja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Datos de la Granja"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:id="@+id/tvSubtituloGranja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Consulta y gestiona la información principal de la granja"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>
        <LinearLayout
            android:id="@+id/cardGranja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginBottom="20dp">
            <TextView
                android:id="@+id/tvNombreGranja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:id="@+id/tvUbicacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ubicación"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>
            <TextView
                android:id="@+id/tvTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teléfono"
                android:textSize="18sp"/>
        </LinearLayout>
        <TextView
            android:id="@+id/tvMensajeSinGranja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Todavía no hay ninguna granja registrada."
            android:textSize="16sp"
            android:textColor="#666666"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>
        <Button
            android:id="@+id/btnCrearGranja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="➕ Crear granja"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>
        <Button
            android:id="@+id/btnEditarGranja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✏️ Editar datos"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"/>
    </LinearLayout>
</ScrollView>