<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/hero_veterinario_tratamiento" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/vet_overlay_gradient" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="92dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="185dp"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:shadowColor="#99000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    android:text="Bienvenido,"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvNombreUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="serif"
                    android:shadowColor="#CC000000"
                    android:shadowDx="0"
                    android:shadowDy="3"
                    android:shadowRadius="10"
                    android:text=""
                    android:textColor="#FFF8EA"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:shadowColor="#99000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    android:text="Gestión Veterinaria"
                    android:textColor="#A5D6A7"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="22dp">

                <!-- Animales — card protagonista, ancho completo -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnAnimalesVet"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/dashboard_card_ripple"
                    android:stateListAnimator="@animator/dashboard_card_state"
                    app:cardBackgroundColor="#00FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="8dp"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/dashboard_transparent_panel"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ANIMALES"
                                android:textColor="#A5D6A7"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Gestión del rebaño"
                                android:textColor="#FFFFFF"
                                android:textSize="21sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Fichas · Historial · Seguimiento"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#66FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Sanitarios + Reproductivos — fila de dos columnas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSanitario"
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        android:stateListAnimator="@animator/dashboard_card_state"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/dashboard_transparent_panel"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Sanitarios"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Vacunas · Tratamientos"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnReproductivo"
                        android:layout_width="0dp"
                        android:layout_height="88dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/dashboard_card_ripple"
                        android:stateListAnimator="@animator/dashboard_card_state"
                        app:cardBackgroundColor="#00FFFFFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="6dp"
                        app:contentPadding="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/dashboard_transparent_panel"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Reproductivos"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Partos · Ciclos"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Alertas — ancho completo, acento ámbar -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnAlertas"
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:layout_marginTop="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/dashboard_card_ripple"
                    android:stateListAnimator="@animator/dashboard_card_state"
                    app:cardBackgroundColor="#00FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="6dp"
                    app:contentPadding="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/dashboard_transparent_panel"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="22dp"
                        android:paddingEnd="22dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ALERTAS"
                                android:textColor="#FFD180"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.12"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Avisos veterinarios"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#66FFFFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/btnCerrarSesion"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/dashboard_logout_button"
        android:contentDescription="@null"
        android:elevation="6dp"
        android:padding="14dp"
        android:src="@drawable/ic_power" />

</FrameLayout>
