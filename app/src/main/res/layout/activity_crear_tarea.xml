<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NUEVA TAREA"
            android:textSize="11sp"
            android:textColor="@color/primary_light"
            android:letterSpacing="0.12"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Asignar tarea a peón"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                card_view:cardCornerRadius="12dp"
                card_view:cardElevation="1dp"
                card_view:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PEÓN ASIGNADO"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:layout_marginBottom="6dp"/>

                    <Spinner
                        android:id="@+id/spinnerPeon"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/edittext_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="20dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="20dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TÍTULO"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etTituloTarea"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ej: Vacunar lote Norte"
                        android:inputType="textCapSentences"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:background="@drawable/edittext_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="20dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="20dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DESCRIPCIÓN"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etDescripcionTarea"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Describe los pasos a seguir"
                        android:inputType="textCapSentences|textMultiLine"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:background="@drawable/edittext_bg"
                        android:padding="12dp"
                        android:minLines="4"
                        android:gravity="top"
                        android:layout_marginBottom="20dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="20dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="FECHA DE VENCIMIENTO"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etFechaTarea"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="DD/MM/AAAA"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:background="@drawable/edittext_bg"
                        android:padding="12dp"
                        android:focusable="false"
                        android:clickable="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnGuardarTarea"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Guardar tarea"
                android:textSize="14sp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:letterSpacing="0.04"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
